# 忽略所有目录下的 __pycache__ 文件夹（包括configs、models、utils下的）
__pycache__/


# 忽略根目录 data 文件夹下所有内容
/data/**

# 例外：只追踪 data_loader.py
!/data/data_loader.py

# 例外：只追踪 holmes_dataset 文件夹（及其内部所有内容）
data/holmes_dataset/*
!data/holmes_dataset/.gitkeep

logs/*

outputs/*

# 可选补充：忽略Python编译生成的字节码文件（和__pycache__配套，推荐添加）
*.pyc
*.pyo
*.pyd

# 可选：忽略Python虚拟环境/环境变量文件（如果有）
.venv/
env/
.env